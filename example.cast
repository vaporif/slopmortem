[142.365387, "o", "220;198mв”‚\u001b[7;25H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m 9.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mв”‚\u001b[7;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m Near-identical model: both accept consumer crypto deposits (stablecoins and BTC), pay tiered yield funded by lending to institutional borrowers/market makers\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m, charge no account fees, and operate via web and mobile apps. Celsius explicitly offered up to 6.2% on BTC deposits and 0вЂ“\u001b[8;130H8.95% on loans вЂ”\u001b[8;146H the same rate band the pitch describes. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mв”‚\u001b[8;188H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m   \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  5 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mв”‚\u001b[9;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m market \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m    "]
