[132.119388, "o", "7m\u001b[48;2;234;228;202m  \u001b(B\u001b[m\u001b[38;2;157;169;160m\u001b[48;2;232;220;198m203 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;250;243;232m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  1 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mBoth companies take custody of consumer crypto assets (stablecoins and BTC) and re-deploy those assets to third-party borrowers or trading counterparties to generate returns. The funda\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mmental risk profile —\u001b[21;28H customer deposits lent to undisclosed or loosely governed counterparties —\u001b[21;103H is the same structural vulnerability. Both target US consumers and market themselves on\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b"]
[132.119441, "o", "[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m yield and safety. FTX's failure is the canonical example of what happens when this model breaks down.                                                                                  \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  2 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  3 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mWhere diverged:                                                                                                                                                                         \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  4 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m       "]
