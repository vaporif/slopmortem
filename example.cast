[143.704667, "o", "   \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  2 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[16;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mno deposit insurance or consumer protection backstop                                                                                                                                  \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  1 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[17;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mcontagion from broader crypto market collapse (Luna/Terra crash) triggering bank-run withdrawal demand                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;234;228;202m  \u001b(B\u001b[m\u001b[38;2;157;169;160m\u001b[48;2;232;220;198m82  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;250;243;232m                                                                                                                                                     "]
[143.704753, "o", "                                   \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  1 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mLessons:                                                                                                                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  2 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  3 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[21;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mMatch liability duration to asset duration вЂ”\u001b[21;53H never fund liquid on-demand deposits with illiquid or locked institutional loans.                              "]
[143.70489, "o", "                          \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  4 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[22;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mSecure regulatory clarity on whether yield-bearing crypto accounts constitute securities before onboarding US retail customers, not after cease-and-desist orders arrive.             \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  5 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[23;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mMaintain verifiable, audited proof-of-reserves and publish them publicly so depositors and regulators can confirm solvency in real time.                                              \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  6 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[24;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mSet yield rates only at levels the actual loan book can sustainably fund;"]
