[126.140766, "o", "       \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  7 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[10;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mMaintain a liquidity reserve sufficient to cover a simultaneous withdrawal of at least 20-30% of AUM, and stress-test it against a 50%+ crypto market drawdown.                       \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  6 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[11;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mDisclose all risks transparently in plain language and never publicly deny a liquidity problem that exists —\u001b[11;117H regulatory and reputational penalties for false assurances are severe and\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m criminal.                                                                                                                            "]
