[149.331623, "o", "\u001b[48;2;232;220;198mnal crypto borrowers and market makers as counterparties. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                              \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mв”‚\u001b[30;9H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  7 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mв”‚\u001b[31;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m gtm \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m           \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mв”‚\u001b[31;25H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m 7.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;23"]
