[131.855657, "o", "8m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mUS residents specifically. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                               \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[14;130H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                             \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  5 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[15;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m gtm \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m           \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[15;25H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m 4.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[15;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m FTX used aggressive sports sponsorships, celebrity endorsements, and a mass-market brand campaign ('safe, easy way to get into crypto') to acquire users at s\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b"]
