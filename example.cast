[127.924319, "o", "                                                                                                                                                                        \u001b[20;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m1\u001b[21;4H 2\u001b[22;4H 3\u001b[23;4H 4\r\n\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  5 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[25;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mMaintain on-chain, auditable proof-of-reserves and strict liquidity reserves so a simultaneous market shock and depositor run does not force a withdrawal halt.                       \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  6 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[26;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mNever allow a single strategic investor or credit facility provider to become so large a counterparty that their failure is your failure —\u001b[26;147H the FTX rescue deal became BlockFi's death \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;"]
[127.924401, "o", "2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198msentence.                                                                                                                                                                               \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  7 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[28;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mKeep uninsured cash balances at any single bank below FDIC limits, or use sweep structures, so a bank failure (e.g., SVB) does not add a second simultaneous liquidity crisis.        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  8 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B"]
