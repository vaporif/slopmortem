[129.5157, "o", ";2;232;220;198m 9.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[9;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m Both models custody consumer crypto assets and generate yield by lending those assets to institutional counterparties/market makers. The pitch describes tier\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198med interest rates by lock-up duration, which is functionally identical to Voyager's loyalty-rewards yield product. Core mechanics —\u001b[10;138H take consumer deposits, lend wholesale, pass yield b\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mack —\u001b[11;12H are essentially the same. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[11;40H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                 "]
[129.515752, "o", "                                      \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  4 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[12;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m market \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m        \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[12;25H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m 9.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[12;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m Both target US consumers seeking high yield on crypto holdings (stablecoins and BTC explicitly mentioned in the pitch). The addressable market, regulatory en\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mvironment, and competitive set (CeFi crypto yield) are the same. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                "]
[129.515841, "o", "       \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[14;40H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  5 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[15;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m gtm \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m           \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[15;25H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m 7.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[15;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m Both go direct-to-consumer via web and mobile with no account fees as a primary acquisition hook. Voyager also used commission-fre"]
[129.515893, "o", "e trading as its wedge; the\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m new pitch uses no-fee savings accounts and tiered rates. The channels and incentive structure are closely aligned, though the pitch is more savings-focused than brokerage-focused. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m   \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[17;40H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  6 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[18;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m stage_scale \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;2"]
[129.515926, "o", "32;220;198m   \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[18;25H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m 6.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[18;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m The pitch mentions already custodying 'M of customer assets' (presumably millions), suggesting an early but live product —\u001b[18;156H comparable to Voyager's early grow\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mth phase before it scaled to ~$5.9B AUM. Both are post-launch with real customer assets but pre-institutional-scale, making the stage reasonably comparable even if absolute AUM differs\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                              \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[20;40H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;2"]
