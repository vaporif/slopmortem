[148.848617, "o", "\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 14 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 13 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mLessons:                                                                                                                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 12 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b"]
[148.848678, "o", "[48;2;232;220;198m 11 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[7;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mDiversify institutional borrower counterparties aggressively вЂ”\u001b[7;71H no single borrower or exchange should represent more than a small fraction of the lending book.                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 10 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[8;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mEngage securities regulators proactively before scaling; BlockFi's $100M settlement for unregistered loan products is a precedent that will be applied to identical products.         \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  9 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[9;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mMaintain liquid reserves sufficient to honor withdrawal demands without relying on a credit facility from any single counterparty.                                  "]
[148.848736, "o", "                  \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  8 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[10;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mKeep custodied cash in FDIC-insured accounts or equivalents; BlockFi's $227M exposure to SVB shows operational cash is a secondary risk vector.                                       \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  7 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198mв—Џ\u001b[11;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mBuild explicit circuit-breaker policies (withdrawal gates, collateral top-up triggers) that activate before a counterparty failure becomes a solvency crisis.                         \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  6 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                      "]
