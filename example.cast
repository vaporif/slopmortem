[131.575476, "o", "\u001b[?2026h\u001b[H  188 \u001b(B\u001b[0;1m\u001b[38;2;166;97;48m\u001b[48;2;229;223;197m# Premortem report for (unnamed)\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;229;223;197m                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 14 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 13 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[3;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mEnforce hard borrower concentration limits —\u001b[3;53H no single counterparty should represent more than 10-15% of the loan book; Three Arrows Capital's default alone was fatal.               \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198"]
[131.575577, "o", "m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 12 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[4;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mNever imply or state FDIC insurance on crypto deposits; obtain explicit legal guidance before any marketing claim to avoid regulatory cease-and-desist.                               \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 11 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[5;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mStructure consumer lock-up durations to match or exceed the tenor of institutional loans to eliminate the liquidity mismatch that froze Voyager's withdrawals.                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 10 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[6;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mRequire over-collateralization and real-time margin calls on all institutional loans; unsecured or under-collateralized lending to counterpartie"]
[131.575598, "o", "s like 3AC was the proximate cause of \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mfailure.                                                                                                                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  9 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[8;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mBuild a stress-tested contingency plan for simultaneous borrower default and crypto market drawdown before scaling AUM beyond the current early stage.                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  8 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                      "]
