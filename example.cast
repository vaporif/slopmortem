[129.252573, "o", "(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[34;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m Both go direct-to-consumer via web and mobile with no account fees as a primary acquisition hook. Voyager also used commission-free trading as its wedge; the\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m new pitch uses no-fee savings accounts and tiered rates. The channels and incentive structure are closely aligned, though the pitch is more savings-focused than brokerage-focused. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m   \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[36;40H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                       \u001b[21;7H\u001b["]
