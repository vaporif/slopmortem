[130.174303, "o", "ns:                                                                                                                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 11 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 12 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[33;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mEnforce hard borrower concentration limits —\u001b[33;53H no single counterparty should represent more than 10-15% of the loan book; Three Arrows Capital's default alone was fatal.               \u001b[1;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m3\u001b[4;4H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m11\u001b[7;4H10\u001b[8;5H9\u001b[9;5H8\u001b[10;5H7\u001b[13;5H6\u001b[14;5H"]
