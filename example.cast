[153.439098, "o", ";192;171m\u001b[48;2;232;220;198m  5 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mBoth FTX and the new pitch share the same structural risk: they take custody of customer crypto deposits (stablecoins and BTC) and re-deploy those assets to counterparties (Alameda Res\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mearch for FTX; institutional borrowers and market makers for the new pitch) in order to generate returns that are passed back to customers. This rehypothecation model вЂ”\u001b[9;175H where customer \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mfunds are lent out and the platform's solvency depends on counterparty repayment вЂ”\u001b[10;89H is the precise mechanism that caused FTX's collapse. Both also target consumer-facing crypto audience\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71"]
[153.439149, "o", ";77m\u001b[48;2;232;220;198ms in the US and custody stablecoins.                                                                                                                                                    \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  4 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  3 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mWhere diverged:                                                                                                                                                                         \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  2 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                               "]
