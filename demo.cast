[138.983849, "o", "                                                                                                                            \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  4 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[24;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mUnregistered securities products triggering $100M SEC and multi-state settlement                                                                                                      \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  5 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[25;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mInadequate collateralisation and liquidity buffers against institutional borrower defaults                                                                                            \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  6 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[26;8H \u001b(B\u001b[m\u001b[38;2;62;"]
[138.983867, "o", "71;77m\u001b[48;2;232;220;198m$227M uninsured cash held at Silicon Valley Bank adding secondary loss                                                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  7 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[27;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mContagion from Three Arrows Capital default preceding FTX collapse                                                                                                                    \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  8 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[28;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mDependency on a single rescue acquirer (FTX) that itself became insolvent                                                                                                             \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;23"]
[138.983964, "o", "2;220;198m  9 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 10 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mLessons:                                                                                                                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 11 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 12 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[32;8H \u001b(B"]
[138.984022, "o", "\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mDiversify institutional borrower exposure and require over-collateralisation with real-time margin calls —\u001b[32;115H single-counterparty concentration killed BlockFi.                          \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 13 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[33;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mRegister yield-bearing accounts with the SEC and relevant state regulators before scaling; BlockFi's $100M settlement weakened it structurally before any market shock hit.           \u001b[1;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m6\u001b[3;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m2\u001b[5;4H11\u001b[7;4H10\u001b[8;5H9\u001b[9;5H8\u001b[10;5H7\u001b[13;5H6\u001b[14;5H5\u001b[15;5H4\u001b[16;5H3\r\n\n\n\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  2 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                   "]
[138.984076, "o", "                                                                     \r\n\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;234;228;202m  \u001b(B\u001b[m\u001b[38;2;157;169;160m\u001b[48;2;232;220;198m79  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;250;243;232m                                                                                                                                                                                        \u001b[23;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m1\u001b[24;5H2\u001b[25;5H3\u001b[26;5H4\u001b[27;5H5\u001b[28;5H6\u001b[29;5H7\u001b[30;4H 8\u001b[31;4H 9\u001b[32;5H0\u001b[33;5H1\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 12 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[34;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mMaintain liquid reserves sufficient to honour withdrawals during a 30-day contagion event; BlockFi had to halt withdrawals immediately when FTX froze.                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 13 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;19"]
[138.984115, "o", "8m●\u001b[35;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mKeep uninsured cash at multiple FDIC-insured institutions and diversify banking relationships to avoid a second-order loss channel (cf. BlockFi's $227M at SVB).                      \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 14 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[36;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mAvoid taking emergency rescue capital from a single crypto exchange counterparty; that dependency turned BlockFi's lifeline into a fatal liability.                                   \u001b[22;7H\u001b[?2026l"]
