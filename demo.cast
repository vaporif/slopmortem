[139.594438, "o", ";220;198m 9.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[29;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m Identical market: US retail/consumer crypto savers seeking yield on stablecoins and BTC. Same regulatory jurisdiction and same competitive set (CeFi yield pl\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198matforms). \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                         \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[30;155H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                    \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 10 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[31;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m gtm \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m           \u001b(B\u001b[m\u001b[38;2;62;71;77m"]
[139.594502, "o", "\u001b[48;2;232;220;198m│\u001b[31;25H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m 7.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[31;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m Both target US consumers via web and mobile with no account fees and interest-rate incentives. Voyager also listed on the Toronto Stock Exchange and had a br\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198moader brokerage offering, but the consumer acquisition motion is nearly identical. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[32;155H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                    \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 11 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[33;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m stage_scale \u001b(B\u001b"]
[139.594578, "o", "[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m   \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[33;25H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m 6.0 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[33;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m The pitch is already custodying ~\u001b(B\u001b[m\u001b[38;2;110;58;122m\u001b[48;2;232;220;198m$50M of assets, placing it at an early\u001b(B\u001b[m\u001b[38;2;83;66;65m\u001b[48;2;232;220;198m-\u001b(B\u001b[m\u001b[38;2;110;58;122m\u001b[48;2;232;220;198mtraction stage. Voyager at failure was custodying over $\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m1.3B. Both are post-launch wi\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mth real AUM but the pitch is materially smaller, giving it somewhat more flexibility but also less negotiating power with institutional borrowers. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[34;155H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                    \u001b[1;4H\u001b(B\u001b[m\u001b"]
