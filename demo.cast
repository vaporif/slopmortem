[139.398426, "o", "                     \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  1 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mUS crypto brokerage that paid yield on customer deposits by lending to institutional counterparties, ultimately failing when Three Arrows Capital defaulted on a $666M loan.            \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  2 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  3 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mFailure date: 2022-01-01                                                                                                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b"]
