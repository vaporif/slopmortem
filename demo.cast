[139.873104, "o", ";185;192;171m\u001b[48;2;232;220;198m  9 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 10 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mThe new pitch is structurally a near-clone of Voyager Digital's core business: accept US consumer deposits in crypto (stablecoins, BTC), custody them, and generate yield by deploying c\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mapital to institutional borrowers and market makers. Both use a tiered interest/lock-up model, both target retail users via web and mobile, both rely on institutional counterparty rela\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;2"]
[139.873151, "o", "20;198mtionships to fund the yield promise, and both operate in the same US regulatory environment that ultimately scrutinized Voyager for misleading FDIC/banking insurance claims.           \u001b[1;4H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m06\u001b[2;4H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m14\u001b[3;4H13\u001b[4;4H12\u001b[5;4H11\u001b[6;4H10\u001b[7;5H9\u001b[8;5H8\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  7 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \u001b[10;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m6\u001b[12;5H5\u001b[13;5H4\u001b[15;5H3\u001b[17;5H2\u001b[19;5H1\r\n\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;234;228;202m  \u001b(B\u001b[m\u001b[38;2;157;169;160m\u001b[48;2;232;220;198m114 \u001b[22;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m1\u001b[23;5H2\u001b[24;4H 3\r\n\n\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  4 \u001b(B\u001b[m\u001b[38;2;62"]
