[140.573278, "o", "(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 13 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[4;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mRegulatory cease-and-desist from Federal Reserve and FDIC                                                                                                                             \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 12 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[5;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mContagion exposure to FTX collapse disrupting acquisition process                                                                                                                     \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 11 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[6;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m~$1.3B customer assets frozen with limited recovery                                                      "]
[140.573292, "o", "                                                                             \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 10 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  9 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mLessons:                                                                                                                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  8 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                 "]
[140.57336, "o", "       \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  7 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[10;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mDiversify institutional borrowers aggressively —\u001b[10;57H never allow a single counterparty to represent more than a small fraction of total deployed capital.                                 \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  6 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[11;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mImplement transparent, legally reviewed disclosures about deposit insurance: crypto custodied assets are NOT FDIC-insured and regulators will act if this is misrepresented.          \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  5 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[12;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mMatch lock-up terms on the liability side (customer deposits) to the actual durati"]
[140.573377, "o", "on of loans on the asset side to prevent a run-driven liquidity crisis.                             \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  4 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[13;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mBuild a liquidation and wind-down protocol before you need it —\u001b[13;72H Voyager's bankruptcy froze $270M+ in customer cash for months.                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  3 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[14;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mStress-test institutional borrower concentration: if your largest borrower defaults, model whether you can still honor all customer withdrawals without bankruptcy.                   \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  2 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                          "]
