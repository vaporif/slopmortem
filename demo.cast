[140.769901, "o", "\u001b[?2026h\u001b[H  145 \u001b(B\u001b[0;1m\u001b[38;2;166;97;48m\u001b[48;2;229;223;197m# Premortem report for (unnamed)\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;229;223;197m                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 16 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[2;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mContagion exposure to FTX collapse disrupting acquisition process                                                                                                                     \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 15 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[3;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m~$1.3B customer assets frozen with limited recovery                                                                                                                                   \r"]
[140.770014, "o", "\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 14 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 13 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mLessons:                                                                                                                                                                                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 12 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b"]
[140.77008, "o", "[48;2;232;220;198m 11 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[7;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mDiversify institutional borrowers aggressively —\u001b[7;57H never allow a single counterparty to represent more than a small fraction of total deployed capital.                                 \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 10 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[8;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mImplement transparent, legally reviewed disclosures about deposit insurance: crypto custodied assets are NOT FDIC-insured and regulators will act if this is misrepresented.          \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  9 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[9;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mMatch lock-up terms on the liability side (customer deposits) to the actual duration of loans on the asset side to prevent a run-driven liquidity crisis.           "]
[140.770097, "o", "                  \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  8 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[10;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mBuild a liquidation and wind-down protocol before you need it —\u001b[10;72H Voyager's bankruptcy froze $270M+ in customer cash for months.                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  7 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[11;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mStress-test institutional borrower concentration: if your largest borrower defaults, model whether you can still honor all customer withdrawals without bankruptcy.                   \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  6 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                            "]
