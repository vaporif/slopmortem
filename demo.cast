[139.235409, "o", "                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  3 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mThe only dimension where divergence could exist is timing and regulatory posture —\u001b[8;89H BlockFi operated from 2017 through 2022 and was caught without a registered securities product, resul\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mting in a \u001b(B\u001b[m\u001b[38;2;110;58;122m\u001b[48;2;232;220;198m$100M SEC\u001b(B\u001b[m\u001b[38;2;83;66;65m\u001b[48;2;232;220;198m/\u001b(B\u001b[m\u001b[38;2;110;58;122m\u001b[48;2;232;220;198mstate settlement in early 2022 before FTX even collapsed. The new pitch does not describe its regulatory structure (registered vs. unregistered interest accounts), \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b["]
[139.235505, "o", "38;2;110;58;122m\u001b[48;2;232;220;198mcounterparty collateralisation rules, or custody\u001b(B\u001b[m\u001b[38;2;83;66;65m\u001b[48;2;232;220;198m/\u001b(B\u001b[m\u001b[38;2;110;58;122m\u001b[48;2;232;220;198minsurance arrangements, so it is unclear whether those gaps have been addressed. The pitch's ~$\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m50M AUM figure also places it at a much \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198msmaller scale than BlockFi at peak, meaning counterparty concentration risk could be proportionally larger.                                                                             \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  2 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m "]
[139.235588, "o", " \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  1 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mFailure causes:                                                                                                                                                                         \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;234;228;202m  \u001b(B\u001b[m\u001b[38;2;157;169;160m\u001b[48;2;232;220;198m79  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;250;243;232m                                                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  1 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m●\u001b[15;8H \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mCounterparty concentration in FTX / Alameda Research                                                                                                                                  \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;1"]
