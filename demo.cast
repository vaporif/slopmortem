[140.192888, "o", " misrepresented.          \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 13 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m- \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mMatch lock-up terms on the liability side (customer deposits) to the actual duration of loans on the asset side to prevent a run-driven liquidity crisis.                             \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 14 \u001b(B\u001b[m\u001b[38;2;44;99;118m\u001b[48;2;232;220;198m- \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mBuild a liquidation and wind-down protocol before you need it —\u001b[36;72H Voyager's bankruptcy froze $270M+ in customer cash for months.                                                        \u001b[22;7H\u001b[?2026l"]
