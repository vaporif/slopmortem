[140.192222, "o", "20;198m│\u001b[3;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m Both target US consumers via web and mobile with no account fees and interest-rate incentives. Voyager also listed on the Toronto Stock Exchange and had a br\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198moader brokerage offering, but the consumer acquisition motion is nearly identical. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[4;155H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                    \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  9 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[5;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m stage_scale \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m   \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[5;25H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m 6.0 \u001b(B\u001b[m\u001b[38;2;62;71;"]
[140.192251, "o", "77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[5;33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m The pitch is already custodying ~\u001b(B\u001b[m\u001b[38;2;110;58;122m\u001b[48;2;232;220;198m$50M of assets, placing it at an early\u001b(B\u001b[m\u001b[38;2;83;66;65m\u001b[48;2;232;220;198m-\u001b(B\u001b[m\u001b[38;2;110;58;122m\u001b[48;2;232;220;198mtraction stage. Voyager at failure was custodying over $\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m1.3B. Both are post-launch wi\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mth real AUM but the pitch is materially smaller, giving it somewhat more flexibility but also less negotiating power with institutional borrowers. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m│\u001b[6;155H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                    \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  8 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                      "]
