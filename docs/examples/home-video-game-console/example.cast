[129.42028, "o", ";211;186m\u001b[48;2;232;220;198mв”‚\u001b[10;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  Applies because: The pitch mentions 'our own first-party game library' as a feature, but does not confirm titles are complete or compelling; both Atari and Essential Products failed precisely because their exclusive software wasn't strong enough to justify hardware purchas\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;216;211;186m\u001b[48;2;232;220;198mв”‚\u001b[11;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  e.\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 10 \u001b(B\u001b[m\u001b[38;2;216;211;186m\u001b[48;2;232;220;198mв”‚\u001b[12;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  Raised by: Atari (original Inc, multiple bankruptcies), Essential Products (shut down 2020) (2/2)\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m 11 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b["]
