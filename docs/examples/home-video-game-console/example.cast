[142.884682, "o", ";33H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m Both are consumer hardware companies selling physical devices at a one-time purchase price point through direct-to-consumer channels. However, Essential was a pure smartphone manufacturer with no developer licensing or software ecosystem revenue lay\r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mer, whereas the new pitch explicitly includes a third-party developer licensing program as a second revenue stream, making the models only partially analogous. \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                   \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mв”‚\u001b[26;267H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                \r\n\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m  3 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mв”‚\u001b[27;8H\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m"]
