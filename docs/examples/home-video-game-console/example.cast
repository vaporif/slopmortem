[157.535234, "o", "275Hв”Ђ\u001b[16;276Hв”Ђ\u001b[16;277Hв”Ђ\u001b[16;278Hв”Ђ\u001b[16;279Hв”Ђ\u001b[16;280Hв”Ђ\u001b[16;281Hв”Ђ\u001b[16;282Hв”Ђ\u001b[17;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m7 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mWhy similar:\u001b[18;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m6 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                                                                                                                                                                                                                                   \u001b[19;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m5 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mBoth Essential Products and the new pitch are consumer hardware ventures attempting to build a proprietary device platform to compete directly against entrenched, well-capitalized incumbents. Both relied on a single SKU launch with preorders as proof of demand, both face the \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m "]
[157.535286, "o", "   \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mclassic hardware cold-start problem of needing a compelling software/game/app ecosystem to justify the hardware purchase, and both use a one-time purchase monetization model for the physical device. Essential's story of failing to build platform defensibility вЂ”\u001b[20;268H never meaningf\u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m  \u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m    \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mully differentiating from Android OEM competitors вЂ”\u001b[21;58H is directly analogous to the existential challenge a new game console faces against Sony, Microsoft, and Nintendo.\u001b[22;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m4 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m               \u001b[23;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m3 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198mWhere diverged:\u001b[24;5H\u001b(B\u001b[m\u001b[38;2;185;192;171m\u001b[48;2;232;220;198m2 \u001b(B\u001b[m\u001b[38;2;62;71;77m\u001b[48;2;232;220;198m                                                                         "]
