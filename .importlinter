[importlinter]
root_package = slopmortem

[importlinter:contract:corpus-leaf]
name = corpus is a leaf package — outside imports go through __init__
type = forbidden
allow_indirect_imports = True
# Cycle break: llm.tools wraps corpus._tools_impl._tavily_* with budget tracking.
# Lazy imports of _embed_sparse defer the ~150MB fastembed ONNX load past startup.
ignore_imports =
    slopmortem.llm.tools -> slopmortem.corpus._tools_impl
    slopmortem.ingest._ingest -> slopmortem.corpus._embed_sparse
    slopmortem.evals.recording_helper -> slopmortem.corpus._embed_sparse
    slopmortem.stages.retrieve -> slopmortem.corpus._embed_sparse
source_modules =
    slopmortem.cli
    slopmortem.ingest
    slopmortem.pipeline
    slopmortem.stages
    slopmortem.evals
    slopmortem.tracing
    slopmortem.llm
forbidden_modules =
    slopmortem.corpus._chunk
    slopmortem.corpus._disk
    slopmortem.corpus._embed_sparse
    slopmortem.corpus._entity_resolution
    slopmortem.corpus._extract
    slopmortem.corpus._merge
    slopmortem.corpus._merge_text
    slopmortem.corpus._paths
    slopmortem.corpus._qdrant_store
    slopmortem.corpus._reclassify
    slopmortem.corpus._reconcile
    slopmortem.corpus._store
    slopmortem.corpus._summarize
    slopmortem.corpus._tools_impl

[importlinter:contract:llm-leaf]
name = llm is a leaf package — outside imports go through __init__
type = forbidden
allow_indirect_imports = True
source_modules =
    slopmortem.cli
    slopmortem.ingest
    slopmortem.pipeline
    slopmortem.stages
    slopmortem.evals
    slopmortem.corpus
    slopmortem.tracing
forbidden_modules =
